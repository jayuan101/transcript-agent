# ── Transcript Agent — API Keys ───────────────────────────────────────────────
# Copy this file to .env and fill in at least one LLM key.
# All keys are optional except the one for your chosen AI provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / LLM providers (pick one or more) ────────────────────────────────────
ANTHROPIC_API_KEY=          # Claude  — https://console.anthropic.com/keys
OPENAI_API_KEY=             # GPT-4o  — https://platform.openai.com/api-keys
GEMINI_API_KEY=             # Gemini  — https://aistudio.google.com/app/apikey
GROQ_API_KEY=               # Groq    — https://console.groq.com/keys

# ── Speech-to-Text engines (all optional — Whisper runs locally for free) ────
DEEPGRAM_API_KEY=           # https://console.deepgram.com
ASSEMBLYAI_API_KEY=         # https://www.assemblyai.com/dashboard
ELEVENLABS_API_KEY=         # https://elevenlabs.io/app/settings/api-keys
REV_AI_ACCESS_TOKEN=        # https://www.rev.ai/access_token

# ── App settings ──────────────────────────────────────────────────────────────
TZ=America/New_York         # your timezone (e.g. Europe/London, Asia/Tokyo)
